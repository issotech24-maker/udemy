# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin dashboard ──────────────────────────────────────────────────────────
# Simple password gate (replace with Supabase Auth in production)
NEXT_PUBLIC_ADMIN_PASSWORD=admin1234

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Secret token for authenticating cron endpoint calls
CRON_SECRET=your-random-cron-secret-here

# Vercel cron adds this header automatically; for local testing use the same value
# Authorization: Bearer <CRON_SECRET>

# ─── AI (DeepSeek) ────────────────────────────────────────────────────────────
# Required for coupon & scholarship AI generation fallback
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ─── Udemy Partner API (optional) ─────────────────────────────────────────────
# If set, the coupon scraper uses the real Udemy API instead of DeepSeek
UDEMY_CLIENT_ID=your-udemy-client-id
UDEMY_CLIENT_SECRET=your-udemy-client-secret

# ─── Cron trigger from admin (optional) ───────────────────────────────────────
# Expose CRON_SECRET to the browser so the admin "Trigger" button can auth
NEXT_PUBLIC_CRON_SECRET=your-random-cron-secret-here
